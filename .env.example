# Copy to `.env` and fill in. `.env` is gitignored — NEVER commit a real token.
#   cp .env.example .env   &&   edit .env
#
# Hugging Face token (Read or Fine-grained with "read access to gated repos").
# The account behind this token must have ACCEPTED the Llama-3.1 license.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub token (classic PAT with 'repo' scope) — OPTIONAL.
# Only needed by scripts/run_cloud.sh to auto-push results to GitHub. Leave blank to skip publishing.
GH_TOKEN=
